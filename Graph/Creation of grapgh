#include <iostream>
#include <vector>

using namespace std;

class GraphList {
    int V; // Number of vertices
    vector<vector<int>> adj; // Vector of vectors to store edges

public:
    // Constructor
    GraphList(int vertices) {
        V = vertices;
        adj.resize(V);
    }

    // Function to add an edge
    void addEdge(int u, int v, bool bidirectional = true) {
        adj[u].push_back(v);
        if (bidirectional) {
            adj[v].push_back(u); // For undirected graph
        }
    }

    // Function to print the graph
    void printGraph() {
        for (int i = 0; i < V; i++) {
            cout << "Vertex " << i << " is connected to: ";
            for (int neighbor : adj[i]) {
                cout << neighbor << " ";
            }
            cout << endl;
        }
    }
};

int main() {
    int vertices = 5;
    GraphList g(vertices);

    // Adding edges
    g.addEdge(0, 1);
    g.addEdge(0, 4);
    g.addEdge(1, 2);
    g.addEdge(1, 3);
    g.addEdge(1, 4);
    g.addEdge(2, 3);
    g.addEdge(3, 4);

    g.printGraph();

    return 0;
}
