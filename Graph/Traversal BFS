#include <iostream>
#include <vector>
#include <queue> // Used for Level-Order (BFS) Traversal

using namespace std;

// Function to perform BFS traversal using a queue named st
void graphTraversalBFS(int startNode, const vector<vector<int>>& graph, int totalNodes) {
    // 1. Initialize the visited array with false
    vector<bool> visited(totalNodes, false);
    
    // 2. Initialize the queue (named 'st' per requirements)
    queue<int> st;

    // Mark the starting node as visited and push it to the queue
    visited[startNode] = true;
    st.push(startNode);

    cout << "BFS Traversal order: ";

    while (!st.empty()) {
        // Pop the front vertex from the queue
        int currentNode = st.front();
        st.pop();

        cout << currentNode << " ";

        // Get all adjacent vertices of the popped vertex.
        // If an adjacent vertex has not been visited, mark it visited and push it.
        for (int neighbor : graph[currentNode]) {
            if (!visited[neighbor]) {
                visited[neighbor] = true; // Mark visited immediately on discovery
                st.push(neighbor);
            }
        }
    }
    cout << endl;
}

int main() {
    // Graph representation (Same Adjacency List as DFS example)
    int totalNodes = 5;
    vector<vector<int>> graph(totalNodes);

    graph[0] = {1, 2};
    graph[1] = {0, 3, 4};
    graph[2] = {0, 4};
    graph[3] = {1};
    graph[4] = {1, 2};

    // Start BFS traversal from node 0
    graphTraversalBFS(0, graph, totalNodes);

    return 0;
}
