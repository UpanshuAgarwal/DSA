//Using minHeap and unordered_map
class Solution {
public:
    vector<int> topKFrequent(vector<int>& nums, int k) {
        vector<int>result;
        unordered_map<int,int>counts;
        for(auto num : nums){
            counts[num]++;
        }
        priority_queue<pair<int,int>, vector<pair<int,int>>, greater<pair<int,int>>>minHeap;
        for(auto& [element,frequency] : counts){ //for O(1) TC to access data
            minHeap.push({frequency, element});

            if(minHeap.size()>k){
            minHeap.pop();
        }
        }
        while(!minHeap.empty()){
            result.push_back(minHeap.top().second);
            minHeap.pop();
        }
        return result;
    }
};
