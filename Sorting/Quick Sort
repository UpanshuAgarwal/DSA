#include <iostream>
#include <bits/stdc++.h>
#include <vector>
using namespace std;


class Quick{
public:
  Quick(vector<int>& nums, int left, int right){
    quicksort(nums, left, right);
  }
private:
  void quicksort(vector<int>& nums, int left, int right){
    if(left >= right) return;
    int pivotindex = partition(nums, right, left);

    quicksort(nums, left, pivotindex - 1);
    quicksort(nums, pivotindex + 1, right);

  }
  int partition(vector<int>& nums, int right, int left){
        int pivot = nums[right];
        int i = left-1;

        for(int j=left;j<right;j++){
            if(nums[j] < pivot){
                i++;
                swap(nums[i], nums[j]);
            }
        }
        swap(nums[i+1],nums[right]);
        return i+1;

    }
};

int main(){
    int size;
    cout << "Enter size: ";
    cin >> size;

    vector<int> nums(size);
     for(int i=0;i<size;i++){
        cout << "Enter value: "<< endl;
        cin >> nums[i];
     }
     int left = 0;
     int right = size-1;
     Quick q(nums, left, right);

     cout << "Sorted array: ";
    for (int num : nums) {
        cout << num << " ";
    }
    cout << endl;


   

    return 0;
}
