#include <iostream>
#include<vector>
#include<algorithm>
using namespace std;

void merge(vector<int>& v, int left, int mid, int right) {
    vector<int> temp;

    int i = left;     
    int j = mid + 1;   

    while (i <= mid && j <= right) {
        if (v[i] <= v[j]) {
            temp.push_back(v[i]);
            i++;
        } else {
            temp.push_back(v[j]);
            j++;
        }
    }

   
    while (i <= mid) {
        temp.push_back(v[i]);
        i++;
    }

    
    while (j <= right) {
        temp.push_back(v[j]);
        j++;
    }

    for (int k = left; k <= right; k++) {
        v[k] = temp[k - left];
    }
}

void merge_sort(vector<int>& v,int left, int right){
    if (left >= right) return;
    int mid = left + (right-left)/2;
    merge_sort(v, left, mid);
    merge_sort(v, mid+1, right);
    merge(v,left,mid,right);
}

int main(){
    vector<int> vec = {13, 46, 24, 52, 20, 9};
    int n = vec.size();

    merge_sort(vec, 0, n-1);
    for(int i=0;i<n;i++){
        cout << vec[i] << " ";
    }

    return 0;
}
