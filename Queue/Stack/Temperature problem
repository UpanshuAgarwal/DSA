#include<iostream>
#include<vector>
#include<stack>
using namespace std;

class Solution{
    public: vector<int> dailyTemperatures(vector<int>& temp){ // Fixed: changed name to plural 'dailyTemperatures'
        int n = temp.size();
        vector<int> answer(n,0);
        stack<int> st;

        for(int i=0;i<n;++i){
            while(!st.empty() && temp[i] > temp[st.top()]){
                int prevIndex = st.top();
                st.pop();
                answer[prevIndex] = i-prevIndex;
            }
            st.push(i);
        }
        return answer;
    }
};

int main(){
    Solution solver;
    int n;
    cin >> n;
    vector<int> temp(n);
    for(int i=0;i<n;i++){
        cin >> temp[i];
    }
    vector<int> result = solver.dailyTemperatures(temp);
    for(int i=0;i<n;i++){
        cout << result[i] << " ";
    }
    cout << endl;

    return 0;
}
